# Copy this to .env and fill in your keys

# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ElevenLabs (for voice cloning — set after running clone_voice())
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=

# Optional: Brave Search API (better web search). Get free key at brave.com/search/api
BRAVE_API_KEY=

# ARIA identity
USER_NAME=Your Name Here

# Server config (defaults work fine on Pi 5)
HOST=0.0.0.0
PORT=8000
DB_PATH=aria.db
WHISPER_MODEL=tiny.en
